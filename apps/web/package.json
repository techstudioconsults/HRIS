{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --port 3002",
    "analyze": "ANALYZE=true next build --webpack",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "svg:optimize": "svgo --config=svgo.config.mjs --folder public/images --recursive",
    "svg:check": "svgo --config=svgo.config.mjs --folder public/images --recursive --output .svgo-check --quiet"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@workspace/ui": "workspace:*",
    "gsap": "^3.14.2",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^20.19.9",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "^2.1.8",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/test-utils": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.32.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
