{
  "name": "user-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Kingsley Ifijeh",
    "url": "https://github.com/kinxlo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "analyze": "next experimental-analyze",
    "build": "next build --turbopack",
    "start": "next start --port 3000",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "pnpm --dir ../.. exec playwright test --project=chromium apps/user-dashboard",
    "test:e2e:ui": "pnpm --dir ../.. exec playwright test --ui --project=chromium apps/user-dashboard",
    "svg:optimize": "svgo --config=svgo.config.mjs --folder public/images --recursive",
    "svg:check": "svgo --config=svgo.config.mjs --folder public/images --recursive --output .svgo-check --quiet"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@hookform/resolvers": "^3.10.0",
    "@serwist/turbopack": "^9.5.7",
    "@tanstack/react-query": "^5.83.0",
    "@workspace/ui": "workspace:*",
    "axios": "1.15.0",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "eventsource": "^4.0.0",
    "file-saver": "^2.0.5",
    "kbar": "0.1.0-beta.48",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.8.16",
    "nuqs": "^2.4.3",
    "postcss": "8.4.49",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.61.1",
    "react-phone-number-input": "^3.4.12",
    "recharts": "^2.15.0",
    "serwist": "^9.5.7",
    "sharp": "^0.33.5",
    "sonner": "^1.7.4",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.11",
    "use-debounce": "^10.0.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/file-saver": "2.0.7",
    "@types/node": "^20.19.9",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "^2.1.8",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/test-utils": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "esbuild": "0.25.12",
    "vitest": "^2.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
