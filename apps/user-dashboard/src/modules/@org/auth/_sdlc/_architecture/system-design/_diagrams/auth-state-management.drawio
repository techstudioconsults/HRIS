          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm_e18" value="clearUser()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;" parent="1" source="use_logout_node" target="auth_store_node" edge="1">
