        <mxCell id="login_view" value="&lt;b&gt;LoginView&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;useLoginWithPassword()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;fontColor=#ffffff;strokeColor=#0B4884;fontSize=10;" parent="lane_react" vertex="1">
