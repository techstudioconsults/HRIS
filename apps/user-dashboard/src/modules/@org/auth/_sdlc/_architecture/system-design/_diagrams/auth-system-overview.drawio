          <mxGeometry x="980" y="450" width="460" height="285" as="geometry" />
        </mxCell>
        <mxCell id="post_session" value="&lt;b&gt;POST /api/auth/session&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Receives { employee, tokens,&lt;br&gt;permissions }, sets 3&lt;br&gt;HTTP-only cookies&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;strokeColor=#7A4E9E;fontSize=10;" parent="bff_cnt" vertex="1">
          <mxGeometry x="20" y="50" width="190" height="100" as="geometry" />
        </mxCell>
        <mxCell id="get_token" value="&lt;b&gt;GET /api/auth/token&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Reads __hris_at cookie,&lt;br&gt;returns { accessToken,&lt;br&gt;expiresAt }&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;strokeColor=#7A4E9E;fontSize=10;" parent="bff_cnt" vertex="1">
          <mxGeometry x="240" y="50" width="190" height="100" as="geometry" />
        </mxCell>
        <mxCell id="delete_session" value="&lt;b&gt;DELETE /api/auth/session&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Clears all 3&lt;br&gt;HTTP-only cookies&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;strokeColor=#7A4E9E;fontSize=10;" parent="bff_cnt" vertex="1">
          <mxGeometry x="20" y="185" width="190" height="80" as="geometry" />
