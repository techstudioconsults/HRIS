{
  "name": "hris-mono-repo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:user": "turbo dev --filter=user-dashboard",
    "dev:controller": "turbo dev --filter=controller-dashboard",
    "build:web": "turbo build --filter=web",
    "build:user": "turbo build --filter=user-dashboard",
    "build:controller": "turbo build --filter=controller-dashboard",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@vercel/speed-insights",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp"
    ]
  }
}
