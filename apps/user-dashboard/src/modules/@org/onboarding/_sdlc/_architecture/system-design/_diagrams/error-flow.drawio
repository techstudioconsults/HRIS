        <mxCell id="note" value="Note: OnboardingRouteGuard renders a loading spinner during isPending and only redirects once data is fetched." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=9;rounded=1;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="40" y="450" width="600" height="24" as="geometry" />
        </mxCell>
      </root>
