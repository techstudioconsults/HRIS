          <mxGeometry x="240" y="55" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="get_session" value="&lt;b&gt;getSession()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;[Async Function]&lt;br&gt;Server-safe session fetch&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6b656;fontColor=#ffffff;strokeColor=#b85450;fontSize=10;" parent="session_cnt" vertex="1">
